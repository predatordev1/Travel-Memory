# Terraform state files (contain sensitive infrastructure details)
*.tfstate
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# Variable files (often contain secrets like API keys)
*.tfvars
*.tfvars.json

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json

# Sensitive files
*.pem
*.key
.env